  "definitions": {
    "pbstatisticStatisticAllReq": {
      "type": "object"
    },
    "pbstatisticStatisticInfo": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/pbtenantCloudProvider",
          "title": "云提供商"
        },
        "accountName": {
          "type": "string",
          "title": "账户名称，在config.yaml里配置的name"
        },
        "product": {
          "$ref": "#/definitions/pbtenantCloudProduct",
          "title": "资源类型，参考 tenant.proto 中的 CloudProduct"
        },
        "regionId": {
          "type": "integer",
          "format": "int32",
          "title": "区域Id，参考 tenant.proto 中的各个云的区域"
        },
        "regionName": {
          "type": "string",
          "title": "区域名称，方便可读，参考 tenant.proto 中的各个云的区域"
        },
        "count": {
          "type": "integer",
          "format": "int32",
          "title": "数量"
        }
      }
    },
    "pbstatisticStatisticReq": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/pbtenantCloudProvider"
        }
      }
    },
    "pbstatisticStatisticResp": {
      "type": "object",
      "properties": {
        "cfgs": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/pbstatisticStatisticInfo"
          }
        }
      }
    },
    "pbtenantCloudProduct": {
      "type": "string",
      "enum": [
        "product_all",
        "product_ecs",
        "product_rds",
        "product_domain",
        "product_oss"
      ],
      "default": "product_all",
      "description": "- product_all: 0 - 所有产品\n - product_ecs: 1 - ECS类产品：阿里云ECS,腾讯云CVM，华为云ECS，亚马逊EC2\n - product_rds: 2 - RDS类产品：阿里云RDS,腾讯云CDB\n - product_domain: 3 - Domain类产品：阿里云Domain\n - product_oss: 4 - OSS类产品：阿里云OSS",
      "title": "云产品"
    },
    "pbtenantCloudProvider": {
      "type": "string",
      "enum": [
        "ali",
        "tencent",
        "huawei",
        "aws"
      ],
      "default": "ali",
      "description": "- ali: 0 - 阿里云\n - tencent: 1 - 腾讯云\n - huawei: 2 - 华为云\n - aws: 3 - 亚马逊云",
      "title": "云提供商"
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    }
  }
