{
  "swagger": "2.0",
  "info": {
    "title": "idl/pbrds/rds.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "RdsService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/apis/rds": {
      "post": {
        "summary": "查询RDS全量 - 根据云类型",
        "operationId": "RdsService_ListRds",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/pbrdsListResp"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/pbrdsListReq"
            }
          }
        ],
        "tags": [
          "RdsService"
        ]
      }
    },
    "/apis/rds/all": {
      "post": {
        "summary": "查询所有云的 RDS",
        "operationId": "RdsService_ListRdsAll",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/pbrdsListResp"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/pbrdsListAllReq"
            }
          }
        ],
        "tags": [
          "RdsService"
        ]
      }
    },
    "/apis/rds/detail": {
      "post": {
        "summary": "查询RDS明细 - 支持云类型、区域、账户、分页等过滤条件",
        "operationId": "RdsService_ListRdsDetail",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/pbrdsListDetailResp"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/pbrdsListDetailReq"
            }
          }
        ],
        "tags": [
          "RdsService"
        ]
      }
    }
  },
  "definitions": {
    "pbrdsListAllReq": {
      "type": "object"
    },
    "pbrdsListDetailReq": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/pbtenantCloudProvider",
          "title": "云名称"
        },
        "accountName": {
          "type": "string",
          "title": "账户名称，根据config.yaml中的配置，默认为第一个配置的账户"
        },
        "regionId": {
          "type": "integer",
          "format": "int32",
          "title": "区域Id，参考 tenant.proto 中的各个云的区域"
        },
        "pageNumber": {
          "type": "integer",
          "format": "int32",
          "title": "分页相关参数，页码"
        },
        "pageSize": {
          "type": "integer",
          "format": "int32",
          "title": "分页相关参数，每页数量"
        },
        "nextToken": {
          "type": "string",
          "title": "分页相关参数，下一页的token"
        }
      }
    },
    "pbrdsListDetailResp": {
      "type": "object",
      "properties": {
        "rdses": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/pbrdsRdsInstance"
          },
          "title": "Rds 机器集合"
        },
        "finished": {
          "type": "boolean",
          "title": "查询是否完成，如果为否-false，则可以将下面三个分页参数填入到请求中，继续查询"
        },
        "pageNumber": {
          "type": "integer",
          "format": "int32",
          "title": "分页相关参数，页码"
        },
        "pageSize": {
          "type": "integer",
          "format": "int32",
          "title": "分页相关参数，每页数量"
        },
        "nextToken": {
          "type": "string",
          "title": "分页相关参数，下一页的token"
        },
        "requestId": {
          "type": "string",
          "title": "请求id，出现问题后提供给云厂商，排查问题"
        }
      }
    },
    "pbrdsListReq": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/pbtenantCloudProvider",
          "title": "云名称"
        }
      }
    },
    "pbrdsListResp": {
      "type": "object",
      "properties": {
        "rdses": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/pbrdsRdsInstance"
          },
          "title": "Rds 机器集合"
        }
      }
    },
    "pbrdsRdsInstance": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/pbtenantCloudProvider",
          "title": "云类型"
        },
        "accoutName": {
          "type": "string",
          "title": "账号名称"
        },
        "instanceId": {
          "type": "string",
          "title": "实例id"
        },
        "instanceName": {
          "type": "string",
          "title": "实例名称"
        },
        "regionName": {
          "type": "string",
          "title": "地域，数据中心"
        },
        "instanceType": {
          "type": "string",
          "title": "实例类型"
        },
        "engine": {
          "type": "string",
          "title": "数据库类型"
        },
        "engineVersion": {
          "type": "string",
          "title": "数据库类型的版本"
        },
        "instanceClass": {
          "type": "string",
          "title": "数据库实例规格"
        },
        "status": {
          "type": "string",
          "title": "状态"
        },
        "creationTime": {
          "type": "string",
          "title": "创建时间，ISO8601"
        },
        "expireTime": {
          "type": "string",
          "title": "过期时间"
        },
        "cpu": {
          "type": "integer",
          "format": "int32",
          "title": "vCPU 核数（华为 ListInstances 等返回）"
        },
        "memoryMb": {
          "type": "integer",
          "format": "int32",
          "title": "内存 MB（由控制台/API 的 GB 等换算）"
        },
        "publicIps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "privateIps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "vpcId": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "format": "int32"
        },
        "chargeType": {
          "type": "string",
          "title": "计费类型（如云厂商返回的 charge_info / charging_mode 可读形式）"
        }
      }
    },
    "pbtenantCloudProvider": {
      "type": "string",
      "enum": [
        "ali",
        "tencent",
        "huawei",
        "aws"
      ],
      "default": "ali",
      "description": "- ali: 0 - 阿里云\n - tencent: 1 - 腾讯云\n - huawei: 2 - 华为云\n - aws: 3 - 亚马逊云",
      "title": "云提供商"
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    }
  }
}
