{
  "swagger": "2.0",
  "info": {
    "title": "idl/pbredis/redis.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "RedisService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/apis/redis": {
      "post": {
        "summary": "查询Redis全量 - 根据云类型",
        "operationId": "RedisService_ListRedis",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/pbredisListResp"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/pbredisListReq"
            }
          }
        ],
        "tags": [
          "RedisService"
        ]
      }
    },
    "/apis/redis/all": {
      "post": {
        "summary": "查询所有云的 Redis（华为云 DCS 等）",
        "operationId": "RedisService_ListRedisAll",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/pbredisListResp"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/pbredisListAllReq"
            }
          }
        ],
        "tags": [
          "RedisService"
        ]
      }
    },
    "/apis/redis/detail": {
      "post": {
        "summary": "查询Redis明细 - 支持云类型、区域、账户、分页等过滤条件",
        "operationId": "RedisService_ListRedisDetail",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/pbredisListDetailResp"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/pbredisListDetailReq"
            }
          }
        ],
        "tags": [
          "RedisService"
        ]
      }
    }
  },
  "definitions": {
    "pbredisListAllReq": {
      "type": "object"
    },
    "pbredisListDetailReq": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/pbtenantCloudProvider",
          "title": "云名称"
        },
        "accountName": {
          "type": "string",
          "title": "账户名称，根据config.yaml中的配置，默认为第一个配置的账户"
        },
        "regionId": {
          "type": "integer",
          "format": "int32",
          "title": "区域Id，参考 tenant.proto 中的各个云的区域"
        },
        "pageNumber": {
          "type": "integer",
          "format": "int32",
          "title": "分页相关参数，页码"
        },
        "pageSize": {
          "type": "integer",
          "format": "int32",
          "title": "分页相关参数，每页数量"
        },
        "nextToken": {
          "type": "string",
          "title": "分页相关参数，下一页的token"
        }
      }
    },
    "pbredisListDetailResp": {
      "type": "object",
      "properties": {
        "redises": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/pbredisRedisInstance"
          },
          "title": "Redis 机器集合"
        },
        "finished": {
          "type": "boolean",
          "title": "查询是否完成，如果为否-false，则可以将下面三个分页参数填入到请求中，继续查询"
        },
        "pageNumber": {
          "type": "integer",
          "format": "int32",
          "title": "分页相关参数，页码"
        },
        "pageSize": {
          "type": "integer",
          "format": "int32",
          "title": "分页相关参数，每页数量"
        },
        "nextToken": {
          "type": "string",
          "title": "分页相关参数，下一页的token"
        },
        "requestId": {
          "type": "string",
          "title": "请求id，出现问题后提供给云厂商，排查问题"
        }
      }
    },
    "pbredisListReq": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/pbtenantCloudProvider",
          "title": "云名称"
        }
      }
    },
    "pbredisListResp": {
      "type": "object",
      "properties": {
        "redises": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/pbredisRedisInstance"
          },
          "title": "Redis 机器集合"
        }
      }
    },
    "pbredisRedisInstance": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/pbtenantCloudProvider",
          "title": "云类型"
        },
        "accoutName": {
          "type": "string",
          "title": "账号名称"
        },
        "instanceId": {
          "type": "string",
          "title": "实例id"
        },
        "instanceName": {
          "type": "string",
          "title": "实例名称"
        },
        "regionName": {
          "type": "string",
          "title": "地域，数据中心"
        },
        "size": {
          "type": "integer",
          "format": "int32",
          "title": "实例容量大小，单位:MB"
        },
        "status": {
          "type": "string",
          "title": "状态"
        },
        "creationTime": {
          "type": "string",
          "title": "创建时间，ISO8601"
        },
        "expireTime": {
          "type": "string",
          "title": "过期时间"
        },
        "specCode": {
          "type": "string",
          "title": "产品规格编码（华为 DCS spec_code，可对照规格表看 CPU）"
        },
        "vpcId": {
          "type": "string"
        },
        "publicIps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "privateIps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "usedMemoryMb": {
          "type": "integer",
          "format": "int32",
          "title": "已用内存 MB（华为 DCS used_memory）"
        },
        "chargeType": {
          "type": "string"
        },
        "cpu": {
          "type": "integer",
          "format": "int32",
          "title": "vCPU 核数（华为 DCS：由 ListFlavors 按 spec_code 解析）"
        },
        "envTagValue": {
          "type": "string",
          "title": "环境标识：指定标签键的值（CLOUD_FITTER_REDIS_ENV_TAG_KEY / CLOUD_FITTER_ENV_TAG_KEY）"
        },
        "nodeTagValue": {
          "type": "string",
          "title": "节点标签值（见 CLOUD_FITTER_NODE_TAG_KEY，默认键名 node）"
        },
        "memoryUtilizationAudit": {
          "$ref": "#/definitions/pbutilizationMemoryUtilizationAudit",
          "title": "内存与磁盘利用率审计（DCS）；华为云 CES memory_usage、disk_util_inband 等，其它云未填充"
        }
      }
    },
    "pbtenantCloudProvider": {
      "type": "string",
      "enum": [
        "ali",
        "tencent",
        "huawei",
        "aws"
      ],
      "default": "ali",
      "description": "- ali: 0 - 阿里云\n - tencent: 1 - 腾讯云\n - huawei: 2 - 华为云\n - aws: 3 - 亚马逊云",
      "title": "云提供商"
    },
    "pbutilizationMemoryUtilizationAudit": {
      "type": "object",
      "properties": {
        "memLast30d": {
          "$ref": "#/definitions/pbutilizationUtilizationWindow"
        },
        "memLast180d": {
          "$ref": "#/definitions/pbutilizationUtilizationWindow"
        },
        "diskLast30d": {
          "$ref": "#/definitions/pbutilizationPeriodUtilizationRate"
        },
        "diskLast180d": {
          "$ref": "#/definitions/pbutilizationPeriodUtilizationRate"
        }
      },
      "title": "DCS（Redis）：内存为峰/均/谷；磁盘为期间平均利用率。"
    },
    "pbutilizationPeriodUtilizationRate": {
      "type": "object",
      "properties": {
        "utilizationPercent": {
          "type": "number",
          "format": "double"
        },
        "available": {
          "type": "boolean"
        }
      },
      "title": "时间窗口内单一利用率：对 CES 小时级 average 序列再取算术平均（0–100）。"
    },
    "pbutilizationUtilizationWindow": {
      "type": "object",
      "properties": {
        "peakPercent": {
          "type": "number",
          "format": "double"
        },
        "avgPercent": {
          "type": "number",
          "format": "double"
        },
        "minPercent": {
          "type": "number",
          "format": "double"
        },
        "available": {
          "type": "boolean"
        }
      },
      "title": "某一时间窗口内资源使用率统计（百分比 0–100）：峰 / 均 / 谷。\r\n数据来自华为云监控 CES BatchListMetricData（OpenAPI：POST .../batch-query-metric-data），\r\n对 filter=average、period=3600 返回的序列在本地再算 max/mean/min。"
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    }
  }
}
