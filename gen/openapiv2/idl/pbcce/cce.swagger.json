  "definitions": {
    "pbcceCceCluster": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/definitions/pbtenantCloudProvider"
        },
        "accoutName": {
          "type": "string"
        },
        "regionName": {
          "type": "string"
        },
        "clusterName": {
          "type": "string",
          "title": "metadata.name"
        },
        "clusterUid": {
          "type": "string",
          "title": "metadata.uid"
        },
        "flavor": {
          "type": "string",
          "title": "spec.flavor，如 cce.s2.medium"
        },
        "k8sVersion": {
          "type": "string",
          "title": "spec.version，如 v1.28"
        },
        "phase": {
          "type": "string",
          "title": "status.phase：Available / Unavailable / Creating 等"
        },
        "nodeTotal": {
          "type": "integer",
          "format": "int32",
          "title": "集群下节点总数（ListNodes）"
        },
        "nodeNormal": {
          "type": "integer",
          "format": "int32",
          "title": "正常节点数（节点 phase 为 Active、Installed 等就绪状态）"
        },
        "cpuTotal": {
          "type": "integer",
          "format": "int32",
          "title": "节点 vCPU 合计（据 ECS 规格汇总，无 serverId 或未匹配到规格时为 0）"
        },
        "memoryTotalMb": {
          "type": "integer",
          "format": "int32",
          "title": "节点内存合计（MB，同上）"
        }
      },
      "title": "华为云 CCE 等 Kubernetes 托管集群（字段对应 API 中 metadata / spec / status）"
    },
    "pbcceListDetailReq": {
      "type": "object",
