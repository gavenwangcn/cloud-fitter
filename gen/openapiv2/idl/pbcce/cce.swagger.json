    "pbtenantCloudProvider": {
      "type": "string",
      "enum": [
        "ali",
        "tencent",
        "huawei",
        "aws"
      ],
      "default": "ali",
      "description": "- ali: 0 - 阿里云\n - tencent: 1 - 腾讯云\n - huawei: 2 - 华为云\n - aws: 3 - 亚马逊云",
      "title": "云提供商"
