# 前后端一起构建/启动（须存在本仓库已提交的 cloud-fitter-web/ 源码）
# 仅需后端时：注释掉下一行或清空 COMPOSE_PROFILES=
COMPOSE_PROFILES=full

# SQLite 持久化：宿主机目录 → 容器内 /app/data（与 Dockerfile 中 -sqlitedb=data/cloud-fitter.db 一致）
# 配置管理里保存的云账号写入该目录下的 cloud-fitter.db；可改为绝对路径如 D:/cloud-fitter-data
CLOUD_FITTER_DATA_DIR=./data

# 可选：全资源共用的环境标签键名，不配置时程序内默认使用键 environment（Compose 可只配这一项）
# CLOUD_FITTER_ENV_TAG_KEY=environment
# 可选：全资源共用的「节点」标签键名，默认 node；用于列表与 CMDB 系统节点名（有值用标签值，无值用 云名-地域）
# CLOUD_FITTER_NODE_TAG_KEY=node

# CMDB API（cmdb-sync 与 cloud-fitter 后端共用变量名；secret 含特殊字符时请保持引号）
CLOUD_FITTER_CMDB_BASE_URL=http://172.25.169.33:30800
CLOUD_FITTER_CMDB_KEY=b02ba3c972f04bb2893a1da8563d80e4
CLOUD_FITTER_CMDB_SECRET="g#BOI42T%XeA5Qbdqo6ZWxfkyDHuph^K"

# Go 网络栈参数：禁用 IPv6，强制走 IPv4
GODEBUG=ipv6=0

# —— 以下为 MySQL 存储（docker-compose-mysql / 二进程 CLOUD_FITTER_DB_DRIVER=mysql）示例，与 SQLite 二选一，勿同时启用时混用未迁移数据
# CLOUD_FITTER_DB_DRIVER=mysql
# CLOUD_FITTER_MYSQL_HOST=host.docker.internal
# CLOUD_FITTER_MYSQL_PORT=3306
# CLOUD_FITTER_MYSQL_USER=cloud_fitter
# CLOUD_FITTER_MYSQL_PASSWORD=your_password
# CLOUD_FITTER_MYSQL_DATABASE=cloud_fitter
