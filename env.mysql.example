# 复制为 .env 或与现有 .env 合并。与 docker-compose-mysql.yml / 二进制 main 共用。

# 使用 MySQL 时必须设置为 mysql（默认 sqlite 行为不设置此项）
CLOUD_FITTER_DB_DRIVER=mysql

# 已安装 MySQL 上的库名（需事先 CREATE DATABASE）
CLOUD_FITTER_MYSQL_DATABASE=cloud_fitter
CLOUD_FITTER_MYSQL_USER=cloud_fitter
CLOUD_FITTER_MYSQL_PASSWORD=change_me

# 宿主机/网络可达的地址：本机 127.0.0.1、内网 IP、或 Docker 内访问宿主机用 host.docker.internal（视环境而定）
CLOUD_FITTER_MYSQL_HOST=host.docker.internal
CLOUD_FITTER_MYSQL_PORT=3306

# ---------- 云资源快照（MySQL）与 CMDB 凌晨同步 ----------
# 定时从云 API 全量拉取 ECS/RDS/DCS/DMS/CCE/EIP/ELB 写入 cloud_snap_* 表；默认每 3 小时；设为 false 关闭。
CLOUD_FITTER_RESOURCE_SNAPSHOT_ENABLE=true
CLOUD_FITTER_RESOURCE_SNAPSHOT_INTERVAL=3h

# 为 true 时，每天 02:00 CMDB 全量同步仅从 MySQL 快照表读数据，不再调云 List / 账单 BSS（与快照周期写入的账期一致，默认当月 YYYY-MM）。
# 需先让快照任务至少成功跑完一轮，否则 CMDB 侧资源为空。
CLOUD_FITTER_CMDB_USE_RESOURCE_SNAPSHOT=false
